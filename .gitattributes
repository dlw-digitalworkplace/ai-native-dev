# Let Git normalize text files automatically...
* text=auto
# ...but ALWAYS keep shell scripts LF: CRLF breaks bash on checkout and inside the deployed zip.
*.sh text eol=lf

# Dev/repo-only files — keep them OUT of the shipped plugin zip (git archive honors
# export-ignore). The consumer only needs the runtime: plugin.json, commands, skills, scripts,
# hooks, rubric, project-template, agents.
# Leading slash anchors to the repo root, so e.g. project-template/CLAUDE.md (a runtime file)
# is NOT matched — only the root CLAUDE.md is.
/CLAUDE.md          export-ignore
/GETTING-STARTED.md export-ignore
/design-doc.md      export-ignore
/design-log.md      export-ignore
/deploy.sh          export-ignore
/plans/             export-ignore
