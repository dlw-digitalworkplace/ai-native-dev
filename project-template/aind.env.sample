# Copy to .claude/aind.env and fill in. This file holds SECRETS + per-user overrides only —
# it must be gitignored and NEVER committed. Shared project config (org, repo, code host,
# branches, worktree settings) lives in the checked-in .claude/aind.settings.json instead.
#
# The AIND scripts auto-load this file (walk-up from the working dir), so no manual `source`.

# ADO Personal Access Token: Work Items (read/write) + Code (read/write). Keep secret.
export AZURE_DEVOPS_EXT_PAT="<pat>"

# Optional: human-readable actor for the signature line. Defaults to `git config user.email`,
# then $USER — set it only to override.
# export AIND_ACTOR="you@example.com"
