# Copy to .claude/aind.env, fill in, and `source` it before running AIND commands.
# Add `.claude/aind.env` to .gitignore — it holds a secret PAT.

export AIND_ADO_ORG="https://dev.azure.com/<your-ado-org>"
export AIND_ADO_PROJECT="<your-ado-project>"

# Where the code + pull requests live: github (default) | ado.
export AIND_CODE_HOST="github"
# When AIND_CODE_HOST=github:
export AIND_GH_REPO="<owner>/<repo>"
# When AIND_CODE_HOST=ado (the code PRs live in Azure DevOps Repos):
# export AIND_ADO_REPO="<your-ado-repo>"

export AIND_INTEGRATION_BRANCH="main"
# export AIND_PLAN_BRANCH_PREFIX="aind/plan/"   # optional
# export AIND_LESSONS_BRANCH="aind/lessons"     # optional (GitHub-side); dreaming-phase exhaust
                                                # branch. Default aind/lessons; override only if
                                                # branch protection/naming forbids that name.
# export AIND_ACTOR="you@example.com"           # optional; defaults to git user.email

# ADO Personal Access Token: Work Items (read/write) + Code (read/write). Keep secret.
export AZURE_DEVOPS_EXT_PAT="<pat>"
